# ClearIT Copilot - Configurações de ambiente

# Gemini API (obrigatório para busca semântica e geração de diagnóstico)
GEMINI_API_KEY=sua_chave_aqui

# FreshService (opcional - para busca em tickets reais via API)
FRESHSERVICE_DOMAIN=seu_subdominio
FRESHSERVICE_API_KEY=sua_api_key

# Porta do servidor
PORT=3000
